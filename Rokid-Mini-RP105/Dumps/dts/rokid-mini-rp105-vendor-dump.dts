			thermal-sensors = <0x32 0x03>;

			trips {

				trip-point@0 {
					temperature = <0x11170>;
					hysteresis = <0x3e8>;
					type = "passive";
				};

				trip-point@1 {
					temperature = <0x13880>;
					hysteresis = <0x3e8>;
					type = "passive";
					linux,phandle = <0x33>;
					phandle = <0x33>;
				};

				trip-point@2 {
					temperature = <0x14c08>;
					hysteresis = <0x1388>;
					type = "hot";
				};

				trip-point@3 {
					temperature = <0x3f7a0>;
					hysteresis = <0x3e8>;
					type = "critical";
				};
			};

			cooling-maps {

				cpufreq_cooling_map {
					trip = <0x33>;
					cooling-device = <0x34 0x00 0x04>;
					contribution = <0x400>;
				};

				cpucore_cooling_map {
					trip = <0x33>;
					cooling-device = <0x35 0x00 0x03>;
					contribution = <0x400>;
				};
			};
		};
	};

	dwc3@ff500000 {
		compatible = "synopsys, dwc3";
		status = "okay";
		reg = <0x00 0xff500000 0x00 0x100000>;
		interrupts = <0x00 0x1e 0x04>;
		usb-phy = <0x36 0x37>;
		cpu-type = "gxl";
		clock-src = "usb3.0";
		clocks = <0x0c 0x3b>;
		clock-names = "dwc_general";
	};

	usb2phy@ffe09000 {
		compatible = "amlogic, amlogic-new-usb2";
		status = "okay";
		portnum = <0x04>;
		reg = <0x00 0xffe09000 0x00 0x80 0x00 0xffd01008 0x00 0x04>;
		linux,phandle = <0x36>;
		phandle = <0x36>;
	};

	usb3phy@ffe09080 {
		compatible = "amlogic, amlogic-new-usb3";
		status = "okay";
		portnum = <0x00>;
		reg = <0x00 0xffe09080 0x00 0x20>;
		interrupts = <0x00 0x10 0x04>;
		otg = <0x01>;
		usb_sel = <0x11 0x07 0x00>;  // GPIOAO_7
		gpio-vbus-power = "GPIOAO_5";
		gpios = <0x11 0x05 0x00>; // GPIOAO_5
		linux,phandle = <0x37>;
		phandle = <0x37>;
	};

	dwc2_a {
		compatible = "amlogic, dwc2";
		device_name = "dwc2_a";
		reg = <0x00 0xff400000 0x00 0x40000>;
		status = "okay";
		interrupts = <0x00 0x1f 0x04>;
		pl-periph-id = <0x00>;
		clock-src = "usb0";
		port-id = <0x00>;
		port-type = <0x02>;
		port-speed = <0x00>;
		port-config = <0x00>;
		port-dma = <0x00>;
		port-id-mode = <0x00>;
		usb-fifo = <0x2d8>;
		cpu-type = "gxl";
		controller-type = <0x03>;
		phy-reg = <0xffe09000>;
		phy-reg-size = <0xa0>;
		clocks = <0x0c 0x3b 0x0c 0x41 0x0c 0x39>;
		clock-names = "usb_general", "usb1", "usb1_to_ddr";
	};

	serial@ffd24000 {
		compatible = "amlogic, meson-uart";
		reg = <0x00 0xffd24000 0x00 0x18>;
		interrupts = <0x00 0x1a 0x01>;
		status = "okay";
		clocks = <0x0a 0x0c 0x29>;
		clock-names = "clk_uart", "clk_gate";
		fifosize = <0x80>;
		pinctrl-names = "default";
		pinctrl-0 = <0x38>; // a_uart
	};

	serial@ffd23000 {
		compatible = "amlogic, meson-uart";
		reg = <0x00 0xffd23000 0x00 0x18>;
		interrupts = <0x00 0x4b 0x01>;
		status = "disable";
		clocks = <0x0a 0x0c 0x36>;
		clock-names = "clk_uart", "clk_gate";
		fifosize = <0x40>;
		pinctrl-names = "default";
		pinctrl-0 = <0x39>; // b_uart
	};

	meson-irblaster {
		compatible = "amlogic, am_irblaster";
		dev_name = "meson-irblaster";
		status = "disable";
		pinctrl-names = "default";
		pinctrl-0 = <0x3a>;
	};

	aml_snd_iomap {
		compatible = "amlogic, snd_iomap";
		status = "okay";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		pdm_bus {
			reg = <0x00 0xff632000 0x00 0x20>;
		};

		audiobus_base {
			reg = <0x00 0xff642000 0x00 0x2000>;
		};
	};

	dummy {
		#sound-dai-cells = <0x00>;
		compatible = "amlogic, aml_dummy_codec";
		status = "okay";
		linux,phandle = <0x3d>;
		phandle = <0x3d>;
	};

	meson_sound {
		compatible = "amlogic, sound-card";
		aml-audio-card,name = "AML-AXGSOUND";
		aml-audio-card,hp-det-gpio = <0x11 0x0d 0x00>; // GPIOAO_13
		hp-det-gpio-pull = <0x02>;
		spk_mute = <0x14 0x1b 0x01>; // GPIOA_1
		aml-audio-card,loopback = <0x3b>;

		aml-audio-card,dai-link@0 {
			format = "dsp_a";
			mclk-fs = <0x100>;
			continuous-clock;
			bitclock-master = <0x3c>;
			frame-master = <0x3c>;

			cpu {
				sound-dai = <0x3c>;
				dai-tdm-slot-tx-mask = <0x01>;
				dai-tdm-slot-rx-mask = <0x01>;
				dai-tdm-slot-num = <0x01>;
				dai-tdm-slot-width = <0x20>;
				system-clock-frequency = <0x7d000>;
			};

			codec {
				sound-dai = <0x3d 0x3d>;
			};
		};

		aml-audio-card,dai-link@1 {
			format = "i2s";
			mclk-fs = <0x100>;
			bitclock-master = <0x3e>;
			frame-master = <0x3e>;

			cpu {
				sound-dai = <0x3e>;
				dai-tdm-slot-tx-mask = <0x01 0x01>;
				dai-tdm-slot-rx-mask = <0x01 0x01>;
				dai-tdm-slot-num = <0x02>;
				dai-tdm-slot-width = <0x20>;
				system-clock-frequency = <0xbb8000>;
			};

			codec {
				sound-dai = <0x3d 0x3d>;
			};
		};

		aml-audio-card,dai-link@2 {
			format = "i2s";
			mclk-fs = <0x100>;
			continuous-clock;
			bitclock-master = <0x3f>;
			frame-master = <0x3f>;

			cpu {
				sound-dai = <0x3f>;
				dai-tdm-slot-tx-mask = <0x01 0x01>;
				dai-tdm-slot-rx-mask = <0x01 0x01>;
				dai-tdm-slot-num = <0x02>;
				dai-tdm-slot-width = <0x20>;
				system-clock-frequency = <0xbb8000>;
			};

			codec {
				sound-dai = <0x3d>;
			};
		};

		aml-audio-card,dai-link@3 {
			mclk-fs = <0x100>;

			cpu {
				sound-dai = <0x40>;
			};

			codec {
				sound-dai = <0x3d>;
			};
		};
	};

	bt-dev {
		compatible = "amlogic, bt-dev";
		dev_name = "bt-dev";
		status = "okay";
		gpio_reset = <0x14 0x44 0x00>; // GPIOX_21
	};

	wifi {
		compatible = "amlogic, aml_wifi";
		dev_name = "aml_wifi";
		status = "okay";
		interrupt_pin = <0x14 0x35 0x00>; // GPIOX_6
		irq_trigger_type = "GPIO_IRQ_LOW";
		power_on_pin = <0x14 0x36 0x00>;
		dhd_static_buf;
		pinctrl-names = "default";
		pinctrl-0 = <0x41>;
		pwm_config = <0x42>;
	};

	wifi_pwm_conf {
		linux,phandle = <0x42>;
		phandle = <0x42>;

		pwm_channel1_conf {
			pwms = <0x43 0x00 0x7558 0x00>;
			duty-cycle = <0x3aac>;
			times = <0x0a>;
		};

		pwm_channel2_conf {
			pwms = <0x43 0x02 0x754e 0x00>;
			duty-cycle = <0x3aa7>;
			times = <0x0c>;
		};
	};

	emmc@ffe07000 {
		status = "disabled";
		compatible = "amlogic, meson-aml-mmc";
		reg = <0x00 0xffe07000 0x00 0x2000>;
		interrupts = <0x00 0xda 0x01>;
		pinctrl-names = "emmc_clk_cmd_pins", "emmc_all_pins";
		pinctrl-0 = <0x44>;
		pinctrl-1 = <0x45 0x46>;
		clocks = <0x0c 0x31 0x0c 0x53 0x0c 0x02 0x0c 0x05>;
		clock-names = "core", "clkin0", "clkin1", "clkin2";
		bus-width = <0x08>;
		cap-sd-highspeed;
		cap-mmc-highspeed;
		mmc-ddr-1_8v;
		mmc-hs200-1_8v;
		max-frequency = <0xbebc200>;
		non-removable;
		disable-wp;

		emmc {
			status = "disabled";
			pinname = "emmc";
			ocr_avail = <0x200080>;
			caps = "MMC_CAP_8_BIT_DATA", "MMC_CAP_MMC_HIGHSPEED", "MMC_CAP_SD_HIGHSPEED", "MMC_CAP_NONREMOVABLE", "MMC_CAP_1_8V_DDR", "MMC_CAP_HW_RESET", "MMC_CAP_ERASE", "MMC_CAP_CMD23";
			f_min = <0x61a80>;
			f_max = <0x5f5e100>;
			max_req_size = <0x20000>;
			gpio_dat3 = <0x14 0x0e 0x00>;
			hw_reset = <0x14 0x14 0x00>;
			pinmux_base = <0xff634400>;
			card_type = <0x01>;
		};
	};

	sdio@ffe05000 {
		status = "okay";
		compatible = "amlogic, meson-aml-mmc";
		reg = <0x00 0xffe05000 0x00 0x2000>;
		interrupts = <0x00 0xd9 0x04>;
		pinctrl-names = "sdio_clk_cmd_pins", "sdio_all_pins";
		pinctrl-0 = <0x47>;
		pinctrl-1 = <0x48>;
		clocks = <0x0c 0x30 0x0c 0x4f 0x0c 0x02>;
		clock-names = "core", "clkin0", "clkin1";
		bus-width = <0x04>;
		cap-sd-highspeed;
		cap-mmc-highspeed;
		max-frequency = <0x5f5e100>;
		non-removable;
		disable-wp;

		sdio {
			status = "disabled";
			pinname = "sdio";
			ocr_avail = <0x200080>;
			caps = "MMC_CAP_4_BIT_DATA", "MMC_CAP_MMC_HIGHSPEED", "MMC_CAP_SD_HIGHSPEED", "MMC_CAP_NONREMOVABLE", "MMC_CAP_UHS_SDR12", "MMC_CAP_UHS_SDR25", "MMC_CAP_UHS_SDR50", "MMC_CAP_UHS_SDR104", "MMC_PM_KEEP_POWER", "MMC_CAP_SDIO_IRQ";
			f_min = <0x61a80>;
			f_max = <0xbebc200>;
			max_req_size = <0x20000>;
			pinmux_base = <0xff634400>;
			card_type = <0x03>;
		};
	};

	adc_keypad {
		compatible = "amlogic, adc_keypad";
		status = "disable";
		key_name = "power", "vol-", "vol+", "wifi", "<<", ">>";
		key_num = <0x06>;
		io-channels = <0x49 0x00>;
		io-channel-names = "key-chan-0";
		key_chan = <0x00 0x00 0x00 0x00 0x00 0x00>;
		key_code = <0x74 0x72 0x73 0x8b 0x69 0x6a>;
		key_val = <0x00 0x8f 0x10a 0x185 0x200 0x27b>;
		key_tolerance = <0x28 0x28 0x28 0x28 0x28 0x28>;
	};

	gpio_keypad {
		compatible = "amlogic, gpio_keypad";
		status = "disable";
		scan_period = <0x14>;
		key_num = <0x04>;
		key_name = "power", "val+", "val-", "mute";
		key_code = <0x74 0x73 0x72 0x71>;
		key_pin = <0x14 0x04 0x01 0x14 0x05 0x01 0x14 0x0a 0x01 0x11 0x08 0x01>;
	};

	partitions {
		parts = <0x0b>;
		part-0 = <0x4a>;
		part-1 = <0x4b>;
		part-2 = <0x4c>;
		part-3 = <0x4d>;
		part-4 = <0x4e>;
		part-5 = <0x4f>;
		part-6 = <0x50>;
		part-7 = <0x51>;
		part-8 = <0x52>;
		part-9 = <0x53>;
		part-10 = <0x54>;

		logo {
			pname = "logo";
			size = <0x00 0x2000000>;
			mask = <0x01>;
			linux,phandle = <0x4a>;
			phandle = <0x4a>;
		};

		recovery {
			pname = "recovery";
			size = <0x00 0x2000000>;
			mask = <0x01>;
			linux,phandle = <0x4b>;
			phandle = <0x4b>;
		};

		rsv {
			pname = "rsv";
			size = <0x00 0x800000>;
			mask = <0x01>;
			linux,phandle = <0x4c>;
			phandle = <0x4c>;
		};

		tee {
			pname = "tee";
			size = <0x00 0x800000>;
			mask = <0x01>;
			linux,phandle = <0x4d>;
			phandle = <0x4d>;
		};

		crypt {
			pname = "crypt";
			size = <0x00 0x2000000>;
			mask = <0x01>;
			linux,phandle = <0x4e>;
			phandle = <0x4e>;
		};

		misc {
			pname = "misc";
			size = <0x00 0x2000000>;
			mask = <0x01>;
			linux,phandle = <0x4f>;
			phandle = <0x4f>;
		};

		instaboot {
			pname = "instaboot";
			size = <0x00 0x400000>;
			mask = <0x01>;
			linux,phandle = <0x50>;
			phandle = <0x50>;
		};

		boot {
			pname = "boot";
			size = <0x00 0x2000000>;
			mask = <0x01>;
			linux,phandle = <0x51>;
			phandle = <0x51>;
		};

		system {
			pname = "system";
			size = <0x00 0x80000000>;
			mask = <0x01>;
			linux,phandle = <0x52>;
			phandle = <0x52>;
		};

		cache {
			pname = "cache";
			size = <0x00 0x20000000>;
			mask = <0x02>;
			linux,phandle = <0x53>;
			phandle = <0x53>;
		};

		data {
			pname = "data";
			size = <0xffffffff 0xffffffff>;
			mask = <0x04>;
			linux,phandle = <0x54>;
			phandle = <0x54>;
		};
	};

	unifykey {
		compatible = "amlogic, unifykey";
		status = "ok";
		unifykey-num = <0x08>;
		unifykey-index-0 = <0x55>;
		unifykey-index-1 = <0x56>;
		unifykey-index-2 = <0x57>;
		unifykey-index-3 = <0x58>;
		unifykey-index-4 = <0x59>;
		unifykey-index-5 = <0x5a>;
		unifykey-index-6 = <0x5b>;
		unifykey-index-7 = <0x5c>;

		key_0 {
			key-name = "sn";
			key-device = "normal";
			key-permit = "write", "read", "del";
			linux,phandle = <0x55>;
			phandle = <0x55>;
		};

		key_1 {
			key-name = "seed";
			key-device = "normal";
			key-permit = "write", "read", "del";
			linux,phandle = <0x56>;
			phandle = <0x56>;
		};

		key_2 {
			key-name = "pcbasn";
			key-device = "normal";
			key-permit = "write", "read", "del";
			linux,phandle = <0x57>;
			phandle = <0x57>;
		};

		key_3 {
			key-name = "usid";
			key-device = "normal";
			key-permit = "read", "write", "del";
			linux,phandle = <0x58>;
			phandle = <0x58>;
		};

		key_4 {
			key-name = "mac_bt";
			key-device = "normal";
			key-permit = "read", "write", "del";
			key-type = "mac";
			linux,phandle = <0x59>;
			phandle = <0x59>;
		};

		key_5 {
			key-name = "mac_wifi";
			key-device = "normal";
			key-permit = "read", "write", "del";
			key-type = "mac";
			linux,phandle = <0x5a>;
			phandle = <0x5a>;
		};

		key_6 {
			key-name = "deviceid";
			key-device = "normal";
			key-permit = "read", "write", "del";
			linux,phandle = <0x5b>;
			phandle = <0x5b>;
		};

		key_7 {
			key-name = "factory_date";
			key-device = "normal";
			key-permit = "read", "write", "del";
			linux,phandle = <0x5c>;
			phandle = <0x5c>;
		};
