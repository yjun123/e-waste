/dts-v1/;

/ {
	model = "Rokid";
	amlogic-dt-id = "banban_m_a113";
	compatible = "amlogic, axg";
	interrupt-parent = <0x01>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;

	cpus {
		#address-cells = <0x02>;
		#size-cells = <0x00>;

		cpu-map {

			cluster0 {

				core0 {
					cpu = <0x02>;
				};

				core1 {
					cpu = <0x03>;
				};

				core2 {
					cpu = <0x04>;
				};

				core3 {
					cpu = <0x05>;
				};
			};
		};

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53", "arm,armv8";
			reg = <0x00 0x00>;
			enable-method = "psci";
			clocks = <0x06 0x00>;
			clock-names = "cpu-cluster.0";
			cpu-idle-states = <0x07>;
			linux,phandle = <0x02>;
			phandle = <0x02>;
		};

		cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53", "arm,armv8";
			reg = <0x00 0x01>;
			enable-method = "psci";
			clocks = <0x06 0x00>;
			clock-names = "cpu-cluster.0";
			cpu-idle-states = <0x07>;
			linux,phandle = <0x03>;
			phandle = <0x03>;
		};

		cpu@2 {
			device_type = "cpu";
			compatible = "arm,cortex-a53", "arm,armv8";
			reg = <0x00 0x02>;
			enable-method = "psci";
			clocks = <0x06 0x00>;
			clock-names = "cpu-cluster.0";
			cpu-idle-states = <0x07>;
			linux,phandle = <0x04>;
			phandle = <0x04>;
		};

		cpu@3 {
			device_type = "cpu";
			compatible = "arm,cortex-a53", "arm,armv8";
			reg = <0x00 0x03>;
			enable-method = "psci";
			clocks = <0x06 0x00>;
			clock-names = "cpu-cluster.0";
			cpu-idle-states = <0x07>;
			linux,phandle = <0x05>;
			phandle = <0x05>;
		};

		idle-states {
			entry-method = "arm,psci-0.2";

			cpu-sleep-0 {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x10000>;
				local-timer-stop;
				entry-latency-us = <0x1388>;
				exit-latency-us = <0x1388>;
				min-residency-us = <0x3a98>;
				linux,phandle = <0x07>;
				phandle = <0x07>;
			};
		};
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x0d 0xff08 0x01 0x0e 0xff08 0x01 0x0b 0xff08 0x01 0x0a 0xff08>;
	};

	timer_bc {
		compatible = "arm, meson-bc-timer";
		reg = <0x00 0xffd0f190 0x00 0x04 0x00 0xffd0f194 0x00 0x04>;
		timer_name = "Meson TimerF";
		clockevent-rating = <0x12c>;
		clockevent-shift = <0x14>;
		clockevent-features = <0x23>;
		interrupts = <0x00 0x3c 0x01>;
		bit_enable = <0x10>;
		bit_mode = <0x0c>;
		bit_resolution = <0x00>;
	};

	arm_pmu {
		compatible = "arm,armv8-pmuv3";
		interrupts = <0x00 0x89 0x04 0x00 0x8a 0x04 0x00 0x99 0x04 0x00 0x9a 0x04>;
	};

	interrupt-controller@2c001000 {
		compatible = "arm,cortex-a15-gic", "arm,cortex-a9-gic";
		#interrupt-cells = <0x03>;
		#address-cells = <0x00>;
		interrupt-controller;
		reg = <0x00 0xffc01000 0x00 0x1000 0x00 0xffc02000 0x00 0x100>;
		interrupts = <0x01 0x09 0xf04>;
		linux,phandle = <0x01>;
		phandle = <0x01>;
	};

	psci {
		compatible = "arm,psci-0.2";
		method = "smc";
	};

	pm {
		compatible = "amlogic, pm";
		device_name = "aml_pm";
		status = "okay";
		reg = <0x00 0xff80023c 0x00 0x04>;
	};

	secmon {
		compatible = "amlogic, secmon";
		memory-region = <0x08>;
		in_base_func = <0x82000020>;
		out_base_func = <0x82000021>;
		reserve_mem_size = <0x300000>;
	};

	securitykey {
		compatible = "aml, securitykey";
		storage_query = <0x82000060>;
		storage_read = <0x82000061>;
		storage_write = <0x82000062>;
		storage_tell = <0x82000063>;
		storage_verify = <0x82000064>;
		storage_status = <0x82000065>;
		storage_list = <0x82000067>;
		storage_remove = <0x82000068>;
		storage_in_func = <0x82000023>;
		storage_out_func = <0x82000024>;
		storage_block_func = <0x82000025>;
		storage_size_func = <0x82000027>;
		storage_set_enctype = <0x8200006a>;
		storage_get_enctype = <0x8200006b>;
		storage_version = <0x8200006c>;
	};

	mhu@c883c400 {
		compatible = "amlogic, meson_mhu";
		reg = <0x00 0xff63c400 0x00 0x4c 0x00 0xfffd3000 0x00 0x800>;
		interrupts = <0x00 0xd1 0x01 0x00 0xd2 0x01>;
		#mbox-cells = <0x01>;
		mbox-names = "cpu_to_scp_low", "cpu_to_scp_high";
		mboxes = <0x09 0x00 0x09 0x01>;
		linux,phandle = <0x09>;
		phandle = <0x09>;
	};

	scpi_clocks {
		compatible = "arm, scpi-clks";

		scpi_clocks@0 {
			compatible = "arm, scpi-clk-indexed";
			#clock-cells = <0x01>;
			clock-indices = <0x00>;
			clock-output-names = "vcpu";
			linux,phandle = <0x06>;
			phandle = <0x06>;
		};
	};

	cpu_iomap {
		compatible = "amlogic, iomap";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		io_cbus_base {
			reg = <0x00 0xffd00000 0x00 0x100000>;
		};

		io_apb_base {
			reg = <0x00 0xffe00000 0x00 0x100000>;
		};

		io_aobus_base {
			reg = <0x00 0xff800000 0x00 0x100000>;
		};

		io_vapb_base {
			reg = <0x00 0xff900000 0x00 0x50000>;
		};

		io_hiu_base {
			reg = <0x00 0xff63c000 0x00 0x10000>;
		};
	};

	xtal-clk {
		compatible = "fixed-clock";
		clock-frequency = <0x16e3600>;
		clock-output-names = "xtal";
		#clock-cells = <0x00>;
		linux,phandle = <0x0a>;
		phandle = <0x0a>;
	};

	rtc {
		compatible = "amlogic, aml_vrtc";
		alarm_reg_addr = <0xff8000a8>;
		timer_e_addr = <0xffd0f188>;
		init_date = "2015/01/01";
		status = "okay";
	};

	cpu_info {
		compatible = "amlogic, cpuinfo";
		status = "okay";
		cpuinfo_cmd = <0x82000044>;
	};

	aml_reboot {
		compatible = "aml, reboot";
		sys_reset = <0x84000009>;
		sys_poweroff = <0x84000008>;
	};

	watchdog@0xffd0f0d0 {
		compatible = "amlogic, meson-wdt";
		status = "okay";
		default_timeout = <0x0a>;
		reset_watchdog_method = <0x00>;
		reset_watchdog_time = <0x02>;
		shutdown_timeout = <0x0a>;
		firmware_timeout = <0x06>;
		suspend_timeout = <0x06>;
		reg = <0x00 0xffd0f0d0 0x00 0x10>;
		clock-names = "xtal";
		clocks = <0x0a>;
	};

	pinctrl@ff800014 {
		compatible = "amlogic,meson-axg-aobus-pinctrl";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		ao-bank@ff800014 {
			reg = <0x00 0xff800014 0x00 0x08 0x00 0xff80002c 0x00 0x04 0x00 0xff800024 0x00 0x08 0x00 0xff800084 0x00 0x04>;
			interrupts = <0x00 0xc8 0x01 0x00 0xc9 0x01>;
			reg-names = "mux", "pull", "gpio", "irq";
			gpio-controller;
			#gpio-cells = <0x02>;
			interrupt-controller;
			#interrupt-cells = <0x02>;
			linux,phandle = <0x11>;
			phandle = <0x11>;
		};

		remote_pin {
			linux,phandle = <0x23>;
			phandle = <0x23>;

			mux {
				pins = "GPIOAO_6";
				function = "ir_in";
			};
		};

		irblaster_pin {
			linux,phandle = <0x3a>;
			phandle = <0x3a>;

			mux {
				pins = "GPIOAO_7";
				function = "ir_out";
			};
		};

		ao_uart {
			linux,phandle = <0x0d>;
			phandle = <0x0d>;

			mux {
				pins = "GPIOAO_0", "GPIOAO_1";
				function = "uart_ao_a";
			};
		};

		ao_b_1_uart {

			mux {
				pins = "GPIOAO_4", "GPIOAO_5";
				function = "uart_ao_b";
			};
		};

		ao_i2c {

			mux {
				pins = "GPIOAO_4", "GPIOAO_5";
				function = "i2c_ao";
			};
		};

		ao_i2c_pin1 {

			mux {
				pins = "GPIOAO_8", "GPIOAO_9";
				function = "i2c_ao";
			};
		};

		ao_i2c_pin2 {
			linux,phandle = <0x0b>;
			phandle = <0x0b>;

			mux {
				pins = "GPIOAO_10", "GPIOAO_11";
				function = "i2c_ao";
			};
		};

		s_i2c {
			linux,phandle = <0x28>;
			phandle = <0x28>;

			mux {
				pins = "GPIOAO_10", "GPIOAO_11";
				function = "i2c_slave_ao";
			};
		};
	};

	pinctrl@ff634480 {
		compatible = "amlogic,meson-axg-periphs-pinctrl";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		banks@ff634480 {
			reg = <0x00 0xff634480 0x00 0x40 0x00 0xff6344e8 0x00 0x14 0x00 0xff634520 0x00 0x14 0x00 0xff634430 0x00 0x3c 0x00 0xffd0f080 0x00 0x10>;
			interrupts = <0x00 0x40 0x01 0x00 0x41 0x01 0x00 0x42 0x01 0x00 0x43 0x01 0x00 0x44 0x01 0x00 0x45 0x01 0x00 0x46 0x01 0x00 0x47 0x01>;
			reg-names = "mux", "pull", "pull-enable", "gpio", "irq";
			gpio-controller;
			#gpio-cells = <0x02>;
			interrupt-controller;
			#interrupt-cells = <0x02>;
			linux,phandle = <0x14>;
			phandle = <0x14>;
		};

		external_eth_pins {

			mux {
				groups = "GPIOY_0", "GPIOY_1", "GPIOY_2", "GPIOY_3", "GPIOY_4", "GPIOY_5", "GPIOY_6", "GPIOY_7", "GPIOY_8", "GPIOY_9", "GPIOY_10", "GPIOY_11", "GPIOY_12", "GPIOY_13";
				function = "eth";
			};
		};

		ao_b_uart {
			linux,phandle = <0x0e>;
			phandle = <0x0e>;

			mux {
				pins = "GPIOZ_8", "GPIOZ_9";
				function = "uart_ao_b";
			};
		};

		a_uart {
			linux,phandle = <0x38>;
			phandle = <0x38>;

			mux {
				pins = "GPIOX_8", "GPIOX_9", "GPIOX_10", "GPIOX_11";
				function = "uart_a";
			};
		};

		b_uart {
			linux,phandle = <0x39>;
			phandle = <0x39>;

			mux {
				pins = "GPIOZ_2", "GPIOZ_3";
				function = "uart_b";
			};
		};

		a_i2c {
			linux,phandle = <0x0f>;
			phandle = <0x0f>;

			mux {
				pins = "GPIOZ_6", "GPIOZ_7";
				function = "i2c_a";
			};
		};

		b_i2c {
			linux,phandle = <0x10>;
			phandle = <0x10>;

			mux {
				pins = "GPIOZ_8", "GPIOZ_9";
				function = "i2c_b";
			};
		};

		b_i2c_pin1 {

			mux {
				pins = "GPIOX_16", "GPIOX_17";
				function = "i2c_b";
			};
		};

		c_i2c {
			linux,phandle = <0x12>;
			phandle = <0x12>;

			mux {
				pins = "GPIOX_18", "GPIOX_19";
				function = "i2c_c";
			};
		};

		c_i2c_pin1 {

			mux {
				pins = "GPIOA_17", "GPIOA_18";
				function = "i2c_c";
			};
		};

		d_i2c {
			linux,phandle = <0x13>;
			phandle = <0x13>;

			mux {
				pins = "GPIOA_6", "GPIOA_7";
				function = "i2c_d";
			};
		};

		d_i2c_pin1 {

			mux {
				pins = "GPIOA_12", "GPIOA_13";
				function = "i2c_d";
			};
		};

		d_i2c_pin2 {

			mux {
				pins = "GPIOA_19", "GPIOA_20";
				function = "i2c_d";
			};
		};

		spicc_a_pins {
			linux,phandle = <0x21>;
			phandle = <0x21>;

			mux {
				pins = "GPIOZ_0", "GPIOZ_1", "GPIOZ_2", "GPIOZ_3";
				function = "spi_a";
			};
		};

		spicc_b_pins_A {

			mux {
				pins = "GPIOA_2", "GPIOA_3", "GPIOA_4", "GPIOA_5";
				function = "spi_b";
			};
		};

		spicc_b_pins_X {
			linux,phandle = <0x22>;
			phandle = <0x22>;

			mux {
				pins = "GPIOX_16", "GPIOX_17", "GPIOX_18", "GPIOX_19";
				function = "spi_b";
			};
		};

		nand_pulldown {

			mux {
				pins = "BOOT_0", "BOOT_1", "BOOT_2", "BOOT_3", "BOOT_4", "BOOT_5", "BOOT_6", "BOOT_7", "BOOT_13";
				function = "nandflash";
				bias-pull-down;
			};
		};

		nand_pullup {

			mux {
				pins = "BOOT_8";
				function = "nandflash";
				bias-pull-up;
			};
		};

		all_nand_pins {
			linux,phandle = <0x2d>;
			phandle = <0x2d>;

			mux {
				pins = "BOOT_0", "BOOT_1", "BOOT_2", "BOOT_3", "BOOT_4", "BOOT_5", "BOOT_6", "BOOT_7", "BOOT_8", "BOOT_9", "BOOT_10", "BOOT_11", "BOOT_12", "BOOT_13";
				function = "nandflash";
				input-enable;
			};
		};

		nand_cs {
			linux,phandle = <0x2e>;
			phandle = <0x2e>;

			mux {
				pins = "BOOT_8";
				function = "nandflash";
			};
		};

		emmc_clk_cmd_pins {
			linux,phandle = <0x44>;
			phandle = <0x44>;

			mux {
				pins = "BOOT_8", "BOOT_10";
				function = "emmc";
				input-enable;
				bias-pull-up;
			};
		};

		emmc_conf_pull_up {
			linux,phandle = <0x45>;
			phandle = <0x45>;

			mux {
				pins = "BOOT_0", "BOOT_1", "BOOT_2", "BOOT_3", "BOOT_4", "BOOT_5", "BOOT_6", "BOOT_7", "BOOT_8", "BOOT_10";
				function = "emmc";
				input-enable;
				bias-pull-up;
			};
		};

		emmc_conf_pull_done {
			linux,phandle = <0x46>;
			phandle = <0x46>;

			mux {
				groups = "BOOT_13";
				function = "emmc";
				input-enable;
				bias-pull-down;
			};
		};

		sdio_clk_cmd_pins {
			linux,phandle = <0x47>;
			phandle = <0x47>;

			mux {
				groups = "GPIOX_4", "GPIOX_5";
				function = "sdio";
				input-enable;
				bias-pull-up;
			};
		};

		sdio_all_pins {
			linux,phandle = <0x48>;
			phandle = <0x48>;

			mux {
				groups = "GPIOX_0", "GPIOX_1", "GPIOX_2", "GPIOX_3", "GPIOX_4", "GPIOX_5";
				function = "sdio";
				input-enable;
				bias-pull-up;
			};
		};

		wifi_32k_pins {
			linux,phandle = <0x41>;
			phandle = <0x41>;

			mux {
				groups = "GPIOX_20";
				function = "pwm_a";
			};
		};

		tdmout_a {
			linux,phandle = <0x17>;
			phandle = <0x17>;

			mux {
				pins = "GPIOX_12", "GPIOX_13";
				function = "tdma_out";
			};
		};

		tdmout_a_data {
			linux,phandle = <0x18>;
			phandle = <0x18>;

			mux {
				pins = "GPIOX_15";
				function = "tdma_out1";
			};
		};

		tdmin_a {
			linux,phandle = <0x16>;
			phandle = <0x16>;

			mux {
				pins = "GPIOX_14";
				function = "tdma_in";
			};
		};

		tdmb_mclk {

			mux {
				pins = "GPIOA_1";
				function = "mclk";
			};
		};

		tdmout_b {
			linux,phandle = <0x19>;
			phandle = <0x19>;

			mux {
				pins = "GPIOA_8", "GPIOA_9", "GPIOA_10";
				function = "tdmb_out";
			};
		};

		tdmin_b {
			linux,phandle = <0x1a>;
			phandle = <0x1a>;

			mux {
				pins = "GPIOA_11";
				function = "tdmb_in";
			};
		};

		tdmc_mclk {
			linux,phandle = <0x1b>;
			phandle = <0x1b>;

			mux {
				pins = "GPIOA_0";
				function = "mclk";
			};
		};

		tdmout_c {
			linux,phandle = <0x1c>;
			phandle = <0x1c>;

			mux {
				pins = "GPIOA_2", "GPIOA_3", "GPIOA_4";
				function = "tdmc_out";
			};
		};

		tdmin_c {
			linux,phandle = <0x1d>;
			phandle = <0x1d>;

			mux {
				pins = "GPIOA_5";
				function = "tdmc_in";
			};
		};

		spidfout {
			linux,phandle = <0x1e>;
			phandle = <0x1e>;

			mux {
				pins = "GPIOA_20";
				function = "spdif_out";
			};
		};

		spidfin {
			linux,phandle = <0x1f>;
			phandle = <0x1f>;

			mux {
				pins = "GPIOA_19";
				function = "spdif_in";
			};
		};

		pdmin {
			linux,phandle = <0x20>;
			phandle = <0x20>;

			mux {
				pins = "GPIOA_14", "GPIOA_15", "GPIOA_16";
				function = "pdm";
			};
		};
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		aobus@ff800000 {
			compatible = "simple-bus";
			reg = <0x00 0xff800000 0x00 0xa000>;
			#address-cells = <0x02>;
			#size-cells = <0x02>;
			ranges = <0x00 0x00 0x00 0xff800000 0x00 0xa000>;

			cpu_version {
				reg = <0x00 0x220 0x00 0x04>;
			};

			clock-controller@0 {
				compatible = "amlogic,axg-aoclkc";
				#clock-cells = <0x01>;
				reg = <0x00 0x00 0x00 0x320>;
			};

			i2c@5000 {
				compatible = "amlogic,meson-axg-i2c";
				status = "okay";
				reg = <0x00 0x5000 0x00 0x20>;
				pinctrl-names = "default";
				pinctrl-0 = <0x0b>;
				interrupts = <0x00 0xc3 0x01>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				clocks = <0x0c 0x27>;
				clock-names = "clk_i2c";
			};

			serial@3000 {
				compatible = "amlogic, meson-uart";
				reg = <0x00 0x3000 0x00 0x18>;
				interrupts = <0x00 0xc1 0x01>;
				status = "okay";
				clocks = <0x0a>;
				clock-names = "clk_uart";
				xtal_tick_en = <0x01>;
				fifosize = <0x40>;
				pinctrl-names = "default";
				pinctrl-0 = <0x0d>;  // ao_uart
				support-sysrq = <0x00>;
			};

			serial@4000 {
				compatible = "amlogic, meson-uart";
				reg = <0x00 0x4000 0x00 0x18>;
				interrupts = <0x00 0xc5 0x01>;
				status = "disable";
				clocks = <0x0a>;
				clock-names = "clk_uart";
				fifosize = <0x40>;
				pinctrl-names = "default";
