	circleled {
		compatible = "amlogic, circleled";
		status = "okay";
		led_gpio_sdb = <0x11 0x03 0x00>; // GPIOAO_3
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		sn_i2c0 {
			compatible = "amlogic, sn3236_i2c";
			i2c_bus = "i2c_bus_a";
			reg = <0x3c>;
			led_num = <0x24>;
			led_map = <0x13 0x12 0x14 0x16 0x15 0x17 0x19 0x18 0x1a 0x1c 0x1b 0x1d 0x1f 0x1e 0x20 0x22 0x21 0x23 0x01 0x00 0x02 0x04 0x03 0x05 0x07 0x06 0x08 0x0a 0x09 0x0b 0x0d 0x0c 0x0e 0x10 0x0f 0x11>;
			use_24m_clock = <0x00>;
			status = "okay";
		};

		sn_i2c1 {
			compatible = "amlogic, sn3193_i2c";
			i2c_bus = "i2c_bus_a";
			reg = <0x68>;
			led_num = <0x03>;
			led_map = <0x02 0x01 0x00>;
			use_24m_clock = <0x00>;
			status = "okay";
		};
	};

	led-stage {
		compatible = "rokid, led-stage";
		led_num = <0x27>;
		status = "okay";
		enable_init_light = <0x00>;
		init_pattern_type = <0x01>;
		init_pattern_inter_timems = <0x1e>;
		enable_ota_light = <0x00>;
		ota_raw_data_length = <0x4e>;
		ota_raw_data_inter_timems = <0x12c>;
		ota_raw_data_u8 = [ff 00 00 ff 00 00 ff 00 00 ff 00 00 ff 00 00 ff 00 00 00 ff 00 00 ff 00 00 ff 00 00 ff 00 00 ff 00 00 ff 00 00 ff 00 00 00 ff 00 00 ff 00 00 ff 00 00 ff 00 00 ff 00 00 ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff ff];
	};

	crypto_rokid {
		compatible = "amlogic, rokid_crypto";
		status = "okay";
	};

	touchkey {
		compatible = "amlogic, touchkey";
		status = "okay";
		touch_gpio_en = <0x14 0x2c 0x01>; // GPIOA_18
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		cap_i2c {
			compatible = "amlogic, cap1xxx_i2c";
			i2c_bus = "i2c_bus_ao";
			interrupt = <0x06>; // GPIOAO_6
			reg = <0x28>;
			status = "okay";
		};
	};

	vibrator {
		compatible = "amlogic, vibrator";
		status = "okay";
		dev_name = "vibrator";
		vib_en = <0x14 0x2d 0x00>; // GPIOA_19
		vib_gpio_en = <0x14 0x3f 0x00>;
		pwm = <0x03>;
		polarity = <0x01>;
		duty_cycle = <0xf4240>;
		period = <0xf4240>;
	};
};
